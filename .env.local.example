# ───────────────────────────────────────────────────────────
# Next.js environment — copy to `.env.local` and fill in.
#   cp .env.local.example .env.local
# ───────────────────────────────────────────────────────────

# Base URL of your running Strapi instance (no trailing slash).
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# A Strapi API token with READ access, used for server-side fetches.
# Create it in Strapi: Settings → API Tokens → Create new API Token
# (Token type: Read-only is enough for the public blog).
STRAPI_API_TOKEN=paste-your-read-only-token-here
